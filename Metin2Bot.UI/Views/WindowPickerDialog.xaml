<Window x:Class="Metin2Bot.UI.Views.WindowPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Client Ekle - Pencere Seç" Height="420" Width="520"
        Background="#121212" Foreground="#E0E0E0"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="CLIENT EKLE" FontSize="18" FontWeight="Bold"
                   Foreground="#03DAC6" Margin="0,0,0,12"/>

        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Filtre:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Grid.Column="1" Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}"
                     Background="#1E1E1E" Foreground="White" BorderBrush="#333" Padding="6"/>
            <Button Grid.Column="2" Content="Yenile" Command="{Binding RefreshCommand}"
                    Margin="8,0,0,0" Padding="12,6" Background="#252525" Foreground="White" BorderBrush="#333"/>
        </Grid>

        <ListBox Grid.Row="2"
                 ItemsSource="{Binding Windows}"
                 SelectedItem="{Binding SelectedWindow}"
                 DisplayMemberPath="Title"
                 Background="#0A0A0A" Foreground="#E0E0E0"
                 BorderBrush="#252525" Padding="6">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="6,4"/>
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Görünen ad:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox Grid.Column="1" Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                     Background="#1E1E1E" Foreground="White" BorderBrush="#333" Padding="6"/>
        </Grid>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="OkButton" Content="Ekle" Width="100" Height="32" Margin="0,0,8,0"
                    Background="#03DAC6" Foreground="#121212" FontWeight="Bold" BorderThickness="0"
                    Click="Ok_Click" IsDefault="True"/>
            <Button Content="İptal" Width="100" Height="32"
                    Background="#252525" Foreground="White" BorderBrush="#333"
                    Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
