<Window x:Class="Metin2Bot.UI.Views.SnipOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#33000000"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Cursor="Cross"
        Title="Snip Overlay">
    <Grid x:Name="RootGrid">
        <Canvas x:Name="DrawCanvas"
                Background="Transparent"
                MouseDown="DrawCanvas_MouseDown"
                MouseMove="DrawCanvas_MouseMove"
                MouseUp="DrawCanvas_MouseUp">
            <Rectangle x:Name="SelectionRect"
                       Stroke="#03DAC6" StrokeThickness="2"
                       Fill="#3303DAC6"
                       Visibility="Collapsed"/>
        </Canvas>
        <Border IsHitTestVisible="False" VerticalAlignment="Top" HorizontalAlignment="Center"
                Background="#CC000000" CornerRadius="6" Padding="14,8" Margin="0,16,0,0">
            <TextBlock Foreground="#03DAC6" FontWeight="SemiBold" FontSize="13"
                       Text="Sürükleyerek bir alan seç • ESC ile iptal"/>
        </Border>
    </Grid>
</Window>
